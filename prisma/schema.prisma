generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  studyData     StudyData?
  subscription  Subscription?
  examResults   ExamResult[]
  referralCodeOwned ReferralCode? @relation("ReferralOwner")
  referralCodeUsed  ReferralCode? @relation("ReferralRedeemer")
  buddyPairAsInviter BuddyPair[]  @relation("BuddyInviter")
  buddyPairAsInvitee BuddyPair[]  @relation("BuddyInvitee")
  challengesCreated       Challenge[]
  challengeParticipations ChallengeParticipant[]
  liveSessionsHosted      LiveSession[]
  liveSessionPlayers      LiveSessionPlayer[]
  emailLogs               EmailLog[]
}

model ExamResult {
  id                String   @id @default(cuid())
  userId            String
  examSittingId     String
  candidateNumber   String
  resultDescription String
  outcome           String   // "fail" or "pass" - self-reported, verified by admin
  status            String   @default("pending") // pending | approved | rejected
  adminNotes        String?
  reviewedAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([examSittingId])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Subscription {
  id                  String    @id @default(cuid())
  userId              String    @unique
  stripeCustomerId    String?
  stripeSubscriptionId String?
  examSittingId       String
  examStartDate       String
  examEndDate         String
  monthlyRate         Float
  pricingTier         String
  status              String    @default("active")
  isResubscription    Boolean   @default(false)
  failDiscountApplied Boolean   @default(false)
  startedAt           DateTime  @default(now())
  expiresAt           DateTime
  cancelledAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeSubscriptionId])
  @@index([stripeCustomerId])
  @@index([userId, status])
}

model StudyData {
  id                    String   @id @default(cuid())
  userId                String   @unique
  examDate              String?
  examSittingId         String?
  studyGoal             String   @default("moderate")
  selectedDomains       Json     @default("[\"ethics\",\"assessment\",\"interventions\",\"communication\"]")
  studyStats            Json     @default("{\"totalHours\":0,\"questionsAnswered\":0,\"correctAnswers\":0,\"studyStreak\":0,\"estimatedReadiness\":0}")
  studySessions         Json     @default("[]")
  flashcardProgress     Json     @default("{}")
  practiceResults       Json     @default("[]")
  materialBookmarks     Json     @default("{}")
  materialCompleted     Json     @default("{}")
  engagementData        Json     @default("{}")
  hasCompletedOnboarding Boolean @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GuestStudyData {
  id                     String   @id @default(cuid())
  tokenHash              String   @unique
  examDate               String?
  examSittingId          String?
  studyGoal              String   @default("moderate")
  selectedDomains        Json     @default("[\"ethics\",\"assessment\",\"interventions\",\"communication\"]")
  studyStats             Json     @default("{\"totalHours\":0,\"questionsAnswered\":0,\"correctAnswers\":0,\"studyStreak\":0,\"estimatedReadiness\":0}")
  studySessions          Json     @default("[]")
  flashcardProgress      Json     @default("{}")
  practiceResults        Json     @default("[]")
  materialBookmarks      Json     @default("{}")
  materialCompleted      Json     @default("{}")
  engagementData         Json     @default("{}")
  hasCompletedOnboarding Boolean  @default(false)
  lastSyncedAt           DateTime @default(now())
  expiresAt              DateTime
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([expiresAt])
}

model ReferralCode {
  id          String    @id @default(cuid())
  code        String    @unique
  ownerUserId String    @unique
  expiresAt   DateTime
  redeemedBy  String?   @unique
  redeemedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owner    User  @relation("ReferralOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  redeemer User? @relation("ReferralRedeemer", fields: [redeemedBy], references: [id], onDelete: SetNull)
}

model BuddyPair {
  id                 String    @id @default(cuid())
  inviterUserId      String
  inviteeUserId      String
  status             String    @default("active")
  freeMonthAppliedAt DateTime?
  halfOffActiveFrom  DateTime?
  dissolvedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  inviter User @relation("BuddyInviter", fields: [inviterUserId], references: [id], onDelete: Cascade)
  invitee User @relation("BuddyInvitee", fields: [inviteeUserId], references: [id], onDelete: Cascade)

  @@unique([inviterUserId, inviteeUserId])
  @@index([inviteeUserId])
}

model Challenge {
  id           String   @id @default(cuid())
  joinCode     String   @unique
  creatorId    String
  title        String
  type         String
  targetValue  Int
  domain       String   @default("all")
  startsAt     DateTime @default(now())
  endsAt       DateTime
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  creator      User                   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  participants ChallengeParticipant[]

  @@index([creatorId])
  @@index([status])
  @@index([endsAt])
}

model ChallengeParticipant {
  id                String   @id @default(cuid())
  challengeId       String
  userId            String
  questionsAnswered Int      @default(0)
  correctAnswers    Int      @default(0)
  bestStreak        Int      @default(0)
  score             Int      @default(0)
  lastSessionId     String?
  joinedAt          DateTime @default(now())
  updatedAt         DateTime @updatedAt

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
  @@index([userId])
}

model LiveSession {
  id                   String    @id @default(cuid())
  roomCode             String    @unique
  hostUserId           String
  status               String    @default("lobby")
  currentQuestionIndex Int       @default(0)
  questionStartedAt    DateTime?
  questionDurationSec  Int       @default(20)
  domain               String    @default("all")
  questionCount        Int       @default(10)
  questionIds          Json      @default("[]")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  host    User                @relation(fields: [hostUserId], references: [id], onDelete: Cascade)
  players LiveSessionPlayer[]

  @@index([hostUserId])
  @@index([status])
}

model LiveSessionPlayer {
  id          String   @id @default(cuid())
  sessionId   String
  userId      String
  displayName String
  totalScore  Int      @default(0)
  answers     Json     @default("[]")
  joinedAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt

  session LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([userId])
}

model EmailLog {
  id        String   @id @default(cuid())
  userId    String
  emailType String
  recipient String
  dedupeKey String?
  sentAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, emailType])
  @@index([dedupeKey])
}

// Content tables — questions, flashcards, study materials (DB-backed)
model PracticeQuestionContent {
  id                  String   @id @default(cuid())
  productLine         String
  externalId          String   // original id from TS (e.g. pq-001)
  domain              String
  category            String
  difficulty          String
  question            String   @db.Text
  options             Json
  correctAnswer       Int
  caseStudy           String?  @db.Text
  distractorRationale Json?
  explanation         String   @db.Text
  references         Json?
  clinicalPearls     String?  @db.Text
  questionType        String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([productLine, externalId])
  @@index([productLine, domain])
}

model FlashcardContent {
  id             String   @id @default(cuid())
  productLine    String
  externalId     String
  domain         String
  question       String   @db.Text
  answer         String   @db.Text
  options        Json?
  correctOption  Int?
  category       String
  difficulty     String
  explanation    String?  @db.Text
  references     Json?
  clinicalPearls String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([productLine, externalId])
  @@index([productLine, domain])
}

model StudyMaterialContent {
  id             String   @id @default(cuid())
  productLine    String
  externalId     String
  title          String
  domain         String
  category       String
  content        String   @db.Text
  type           String
  lastUpdated    String
  keyPoints      Json
  commonMistakes Json
  examTips       Json
  references     Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([productLine, externalId])
  @@index([productLine, domain])
}

/// Idempotent Stripe webhook processing (survives serverless cold starts)
model StripeProcessedEvent {
  id        String   @id
  createdAt DateTime @default(now())

  @@index([createdAt])
}

/// Persisted first-party attribution / organic events (optional analytics sink)
model OrganicAnalyticsEvent {
  id        String   @id @default(cuid())
  eventName String
  payload   Json
  createdAt DateTime @default(now())

  @@index([eventName, createdAt])
}
