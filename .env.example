# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Guest cloud save (anonymous progress sync)
NEXT_PUBLIC_ENABLE_GUEST_CLOUD_SAVE="false"

# NextAuth (use your real dev origin, e.g. http://localhost:3000 — must match the URL users open or magic links redirect incorrectly)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""  # Required in production (16+ chars). Used for auth + guest token signing. openssl rand -base64 32

# Resend (magic link emails) - https://resend.com
RESEND_API_KEY=""
# Must match a verified sender domain in Resend (check spelling, e.g. apracademy not aphracademy)
EMAIL_FROM="APRAcademy <noreply@yourdomain.com>"

# Stripe - https://stripe.com
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_BUDDY_FREE_MONTH_COUPON_ID="buddy-free-month"
STRIPE_BUDDY_HALF_OFF_COUPON_ID="buddy-half-off"

# Admin (comma-separated emails that can review exam result submissions)
ADMIN_EMAILS=""

# Cron job authentication (generate with: openssl rand -base64 32)
CRON_SECRET=""

# Sentry - https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# Playwright / local E2E only — never enable in production
E2E_AUTH_BYPASS="false"
NEXT_PUBLIC_E2E_AUTH_BYPASS="false"

# Single-product deploys (set per Vercel project). Omit or "all" = both psych + nursing locally.
# psychology | nursing | all
NEXT_PUBLIC_EXAM_SUITE="all"
